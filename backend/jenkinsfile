
pipeline {
    agent any

    stages {
        stage('Checkout Code') {
            steps {
                git branch: 'master', 
                    url: 'https://github.com/maheshkumar198/File_storage_aws_version.git'
            }
        }

        stage('Verify Files') {
            steps {
                sh 'ls -la'
                sh 'echo "Checkout successful ✅"'
            }
        }
    }
}
