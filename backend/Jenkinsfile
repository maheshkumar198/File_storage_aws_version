pipeline{
    agent { label 'docker-agent' }
  
    environment {
        AWS_REGION = "ap-south-1"
        ECR_REPO = "your-ecr-repo"
        IMAGE_TAG = "latest"
        EC2_HOST = "your-ec2-ip"
        S3_BUCKET = "your-frontend-bucket"
        CLOUDFRONT_ID = "your-cloudfront-id"
        SONAR_PROJECT_KEY = "file-storage"
    }

    stages {

      stage("install"){

        steps {
            dir('backend') {
                sh 'npm install'
            }
        }
      }
      
      stage('Test + Coverage') {
            steps {
                dir('backend') {
                    sh 'npm run test:coverage'
                }
            }
       }

      stage('Dependency Scan') {
            steps {
                dir('backend') {
                    sh 'npm audit --audit-level=high || true'
                }
            }
        }
      
      stage('Trivy FS Scan') {
            steps {
                sh 'trivy fs --exit-code 1 --severity CRITICAL backend'
            }
        }



    }




}